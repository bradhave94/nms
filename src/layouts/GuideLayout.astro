---
import Layout from '@layouts/Layout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import { buildGuideStructuredData } from '@utils/guideStructuredData.js';
import { getSiteOrigin } from '@utils/structuredData.js';
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';

interface Props {
	guide: CollectionEntry<'blog'>;
	headings?: MarkdownHeading[];
}

const { guide, headings = [] } = Astro.props as Props;
const siteOrigin = getSiteOrigin(Astro.site, Astro.url);
const canonicalUrl = new URL(`/blog/${guide.id}/`, siteOrigin).toString();
const ogImage = guide.data.heroImage
	? new URL(guide.data.heroImage, siteOrigin).toString()
	: `${siteOrigin}/images/refiner.webp`;
const tocHeadings = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
const breadcrumbs = [
	{ name: 'Home', href: '/' },
	{ name: 'Blog', href: '/blog' },
	{ name: guide.data.title },
];
const structuredData = buildGuideStructuredData({
	canonicalUrl,
	title: guide.data.title,
	description: guide.data.description,
	publishedTime: guide.data.pubDate.toISOString(),
	modifiedTime: (guide.data.updatedDate ?? guide.data.pubDate).toISOString(),
	authorName: guide.data.author,
	image: ogImage,
	breadcrumbs: breadcrumbs.map((breadcrumb) => ({
		name: breadcrumb.name,
		url: breadcrumb.href ? `${siteOrigin}${breadcrumb.href}` : canonicalUrl,
	})),
	faqs: guide.data.faqs,
});
const tags = guide.data.tags as string[];
const relatedLinks = guide.data.relatedLinks as { label: string; href: string }[];
---

<Layout
	title={`${guide.data.title} | No Man's Sky Recipes`}
	description={guide.data.description}
	slug="blog"
	ogImage={ogImage}
	structuredData={structuredData}
>
	{guide.data.heroImage ? (
		<div class="relative isolate overflow-hidden">
			<img
				src={guide.data.heroImage}
				alt=""
				class="absolute inset-0 -z-10 size-full object-cover brightness-[0.3]"
			/>
			<div class="absolute inset-0 -z-10 bg-gradient-to-t from-[#051413] via-[#051413]/60 to-transparent"></div>
			<div class="mx-auto max-w-7xl px-4">
				<Breadcrumbs items={breadcrumbs} className="pt-6 mb-0 px-0 relative z-10" />
				<div class="mx-auto max-w-3xl py-20 sm:py-28 lg:py-32 text-center">
					<div class="flex items-center justify-center gap-x-4 text-sm">
						<time datetime={guide.data.pubDate.toISOString().slice(0, 10)} class="text-sky-300/90">
							{guide.data.pubDate.toLocaleDateString('en-US', {
								year: 'numeric',
								month: 'long',
								day: 'numeric',
							})}
						</time>
					</div>
					<h1 class="mt-4 text-4xl font-bold tracking-tight text-balance text-white sm:text-5xl lg:text-6xl">{guide.data.title}</h1>
					<p class="mt-6 text-lg font-medium text-pretty text-sky-100/80 sm:text-xl/8">{guide.data.description}</p>
					{tags.length > 0 && (
						<div class="mt-8 flex flex-wrap justify-center gap-2">
							{tags.map((keyword: string) => (
								<span class="rounded-full border border-cyan-400/30 bg-cyan-500/10 px-3 py-1 text-xs font-medium text-cyan-200 backdrop-blur-sm">
									{keyword}
								</span>
							))}
						</div>
					)}
				</div>
			</div>
		</div>
	) : (
		<div class="mx-auto max-w-7xl px-4 pt-10">
			<Breadcrumbs items={breadcrumbs} className="mb-6 px-0" />
		</div>
	)}

	<article class="mx-auto max-w-7xl px-4 py-10">
		<div class="flex justify-center gap-8 xl:items-start">
			<div class="w-full max-w-[680px] min-w-0">

				<div id="guide-content" class="prose prose-invert max-w-none prose-headings:text-white prose-a:text-cyan-300 prose-strong:text-white prose-li:text-sky-100/90 prose-p:text-sky-100/90">
					<slot />
				</div>
				<script>
					document.querySelectorAll('#guide-content table').forEach((table) => {
						if (table.parentElement?.classList.contains('prose-table-scroll')) return;
						const wrapper = document.createElement('div');
						wrapper.className = 'prose-table-scroll';
						table.parentNode?.insertBefore(wrapper, table);
						wrapper.appendChild(table);
					});
				</script>

			{relatedLinks.length > 0 && (
				<section class="mt-10 rounded-lg border border-sky-900/70 bg-sky-950/30 p-6">
					<h2 class="mt-0 text-2xl text-white">Related</h2>
					<ul class="mb-0 mt-4 space-y-3 pl-5 text-sky-100/90">
						{relatedLinks.map((link: { label: string; href: string }) => (
							<li>
								<a href={link.href} class="text-cyan-300 hover:text-cyan-200">
									{link.label}
									</a>
								</li>
							))}
						</ul>
					</section>
				)}
			</div>

			{tocHeadings.length > 0 && (
				<aside class="hidden xl:block w-60 shrink-0 self-start sticky top-4 h-fit">
					<div class="rounded-lg border border-sky-900/70 bg-sky-950/30 p-4">
						<h2 class="mt-0 mb-3 text-lg font-semibold text-white">On this page</h2>
						<ul class="space-y-2 text-sm list-none p-0" id="blog-toc-links">
							{tocHeadings.map((heading) => (
								<li class={heading.depth === 3 ? 'pl-4' : ''}>
									<a
										href={`#${heading.slug}`}
										class="blog-toc-link text-sky-300/80 hover:text-white transition"
										data-section={heading.slug}
									>
										{heading.text}
									</a>
								</li>
							))}
						</ul>
					</div>
				</aside>
			)}
		</div>
	</article>
</Layout>

{tocHeadings.length > 0 && (
	<script define:vars={{ tocHeadings }}>
		const sections = tocHeadings.map((heading) => heading.slug);
		const links = document.querySelectorAll('.blog-toc-link');

		function updateActive() {
			let current = '';
			for (const id of sections) {
				const el = document.getElementById(id);
				if (el) {
					const rect = el.getBoundingClientRect();
					if (rect.top <= 120) current = id;
				}
			}
			links.forEach((link) => {
				const section = link.getAttribute('data-section');
				if (section === current) {
					link.classList.remove('text-sky-300/80');
					link.classList.add('text-white', 'font-semibold', 'border-l-2', 'border-sky-400', 'pl-2');
				} else {
					link.classList.add('text-sky-300/80');
					link.classList.remove('text-white', 'font-semibold', 'border-l-2', 'border-sky-400', 'pl-2');
				}
			});
		}

		window.addEventListener('scroll', updateActive, { passive: true });
		updateActive();
	</script>
)}
