---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import { SITE } from '@config';

const cards = [
	{
		name: 'Refining',
		description:
			'Refining is a process of combining various ingredients with the use of a refiner.',
		button: 'View Recipes',
		image: '/images/refiner.webp',
		link: '/refining',
	},

	{
		name: 'Cooking',
		description:
			'Cooking is a process of combining various ingredients with the use of a Nutrient Processor.',
		button: 'View Recipes',
		image: '/images/cooker.webp',
		link: '/cooking',
	},
	{
		name: 'Crafting',
		description:
			'The player can craft technology upgrades for themselves using blueprints found throughout the universe.',
		button: 'View Recipes',
		image: '/images/crafting.webp',
		link: '/crafting-guide',
	},
	{
		name: 'Blog',
		description:
			'Read the No Man\'s Sky blog for guides, crafting breakdowns, and tips to help you get the most out of No Man\'s Sky.',
		button: 'View Blog',
		image: '/images/items/ACCESS3.png',
		link: '/blog',
	},
	{
		name: 'New Items',
		description:
			`See everything added or updated in the latest No Man\'s Sky patch: ${SITE.version_name} (${SITE.version})`,
		button: 'View New Items',
		image: 'https://nomansskyrecipes.com/images/items/SWARM_ARMOUR.png',
		link: '/new',
	},
	{
		name: 'Calculator',
		description:
			'A calculator for helping your farming efforts by calculating exactly what you need to craft any item.',
		button: 'View Recipes',
		image: '/images/calculator.webp',
		link: '/calculator',
	},
	{
		name: 'Products',
		description:
			'Products are crafted and tradeable outputs used for progression, missions, and high-value selling.',
		button: 'View Recipes',
		image: 'https://nomansskyrecipes.com/images/items/ULTRAPROD1.png',
		link: '/products',
	},
	{
		name: 'Technology',
		description:
			"Technology is an item that upgrades a player's exosuit, multi-tool, exocraft, and starship. You learn how to install technologies from blueprints. ",
		button: 'View Recipes',
		image: 'https://nomansskyrecipes.com/images/items/U_BATTERY_S.png',
		link: '/technology',
	},
	{
		name: 'Upgrades',
		description:
			'Upgrades include inventory expansions, technology unlocks, and module-related enhancement items.',
		button: 'View Recipes',
		image: 'https://nomansskyrecipes.com/images/items/UP_SLASR1.png',
		link: '/upgrades',
	},
	{
		name: 'Exocraft',
		description:
			'Exocraft items cover vehicle modules, customisation options, and upgrades for planetary traversal.',
		button: 'View Recipes',
		image: 'https://nomansskyrecipes.com/images/exocraft.webp',
		link: '/exocraft',
	},
	{
		name: 'Starships',
		description:
			'Starships includes components, upgrades, and starship-specific trade and salvage items.',
		button: 'View Recipes',
		image: 'https://nomansskyrecipes.com/images/items/TWITCH_SHIP17.png',
		link: '/starships',
	},
	{
		name: 'Buildings',
		description:
			'Base building allows the player to build multiple bases, which can be used for farming, storage and recharging Hazard Protection or Shield.',
		button: 'View Recipes',
		image: 'https://nomansskyrecipes.com/images/items/S_COMPOSTBIN.png',
		link: '/buildings',
	},
	{
		name: 'Corvette',
		description:
			'Corvette entries include starship component and progression-related items tied to this category.',
		button: 'View Recipes',
		image: 'https://nomansskyrecipes.com/images/items/B_WNG_R.png',
		link: '/corvette',
	},
	{
		name: 'Creatures',
		description:
			'Creatures and Xeno Arena data including species, battle moves, arena modes, medal tracks, and pet rewards.',
		button: 'View Creatures',
		image: 'https://nomansskyrecipes.com/images/items/SPEC_PB_EGG01.png',
		link: '/creatures',
	},
	{
		name: 'Fish',
		description:
			'Fish items include aquatic catches and related resources used across recipes and exchanges.',
		button: 'View Recipes',
		image: 'https://nomansskyrecipes.com/images/items/F_DEEP_COM_XL.png',
		link: '/fish',
	},
	{
		name: 'Curiosities',
		description:
			'Curiosities are items that can be found in the universe. They can be sold for units or used to craft other items.',
		button: 'View Recipes',
		image: 'https://nomansskyrecipes.com/images/items/BIOSHIP_EGG1.png',
		link: '/curiosities',
	},
	{
		name: 'Food',
		description:
			'Food covers all edible items and cooking ingredients in one place.',
		button: 'View Recipes',
		image: 'https://nomansskyrecipes.com/images/items/FOOD_F_MED1.png',
		link: '/food',
	},
	{
		name: 'Raw Materials',
		description: "List of the raw materials in No Man's Sky",
		button: 'View Recipes',
		image: 'https://nomansskyrecipes.com/images/items/FUEL1.png',
		link: '/raw',
	},
	{
		name: 'Other',
		description:
			'Other items are items that are not in any other category.',
		button: 'View Recipes',
		image: '/images/items/SPEC_EMOTE03.png',
		link: '/other',
	},
	{
		name: 'Feedback',
		description:
			'Feedback is a way to give feedback to the No Man\'s Sky Recipes team. You can submit a bug report, request a feature, or suggest an improvement.',
		button: 'View Feedback',
		image: '/images/items/SPEC_TITLE22.png',
		link: '/feedback',
	}
];
---
<Layout
	title="No Man's Sky Recipes Guide, Refiner Recipes, Crafting & Cooking"
	description="Find No Man's Sky recipes, refiner outputs, crafting chains, blog posts, and item lookup tools for products, upgrades, food, and raw materials."
	slug="home"
	ogImage={`${SITE.website}/images/refiner.webp`}
>
    <header class="bg-linear-to-r from-purple-900/20 to-slate-900/50 py-10 text-center">
        <h1 class="m-0 text-4xl sm:text-6xl text-white font-bold mb-4">No Man's Sky Recipes</h1>
        <p class="m-0 text-xl sm:text-3xl text-gray-300 tracking-widest">
            Refiners | Crafting | Cooking | And more...
        </p>
    </header>

    <main class="container w-auto mx-auto px-4 py-8">
        <div id="items" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-6">
            {cards.map((card, index) => (
                <Card
                    card={card}
                    index={index}
                    loading={index < 4 ? "eager" : "lazy"}
                />
            ))}
        </div>
    </main>
</Layout>
