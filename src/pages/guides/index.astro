---
import Layout from '@layouts/Layout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';
import { buildCollectionStructuredData, getSiteOrigin } from '@utils/structuredData.js';
import { buildPaginatedMeta } from '@utils/seo.js';

const guides = (await getCollection('guides')).sort(
	(a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const titleBase = "No Man's Sky Guides";
const baseDescription =
	"Read No Man's Sky guides for refiner recipes, crafting chains, creature affinities, cooking strategies, and high-value item progression.";
const { title, description } = buildPaginatedMeta(titleBase, baseDescription, 1, 1);
const siteOrigin = getSiteOrigin(Astro.site, Astro.url);
const canonicalUrl = new URL('/guides', siteOrigin).toString();
const structuredData = buildCollectionStructuredData({
	siteOrigin,
	canonicalUrl,
	collectionName: titleBase,
	collectionDescription: baseDescription,
	collectionPath: '/guides',
	currentPage: 1,
	items: guides.map((guide, index) => ({
		name: guide.data.title,
		url: `${siteOrigin}/guides/${guide.id}/`,
		position: index + 1,
	})),
});
const breadcrumbs = [
	{ name: 'Home', href: '/' },
	{ name: 'Guides' },
];
---

<Layout title={title} description={description} slug="guides" structuredData={structuredData}>
	<Breadcrumbs items={breadcrumbs} className="pt-4 mb-6" />
	<section class="mx-auto max-w-6xl px-4 pb-16">
		<header class="mx-auto max-w-4xl text-center">
			<h1 class="m-0 pt-8 text-4xl font-bold text-white sm:text-6xl">No Man&apos;s Sky Guides</h1>
			<p class="mx-auto mt-4 max-w-3xl text-lg text-sky-200/90">
				Detailed how-to guides for profitable crafting, refiner recipes, creature systems, and
				end-game item progression.
			</p>
		</header>

		<div class="mt-12 grid gap-6 md:grid-cols-2">
			{
				guides.map((guide) => (
					<article class="rounded-xl border border-sky-900/70 bg-sky-950/40 p-6 transition hover:border-sky-400/70 hover:bg-sky-900/40">
						<h2 class="mt-3 text-2xl text-white">
							<a href={`/guides/${guide.id}/`} class="hover:text-sky-200">
								{guide.data.title}
							</a>
						</h2>
						<p class="mt-3 text-sky-100/85">{guide.data.description}</p>
						<div class="mt-4 flex flex-wrap gap-2">
							{guide.data.tags.map((tag) => (
								<span class="rounded-full bg-sky-900/70 px-3 py-1 text-xs text-sky-200">{tag}</span>
							))}
						</div>
						<p class="mt-5 text-sm text-sky-300">
							Published {guide.data.pubDate.toLocaleDateString('en-US', {
								year: 'numeric',
								month: 'long',
								day: 'numeric',
							})}
						</p>
					</article>
				))
			}
		</div>
	</section>
</Layout>
