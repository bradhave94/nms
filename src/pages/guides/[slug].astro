---
export function getStaticPaths() {
	return [
		'best-no-mans-sky-refiner-recipes',
		'best-no-mans-sky-cooking-recipes',
		'how-to-craft-fusion-ignitor',
		'how-to-craft-stasis-device',
		'no-mans-sky-creature-affinities-guide',
	].map((slug) => ({
		params: { slug },
	}));
}

const slug = Astro.params.slug ?? '';
return Astro.redirect(`/blog/${slug}`, 301);
---
