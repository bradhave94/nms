---
import Layout from '@layouts/Layout.astro';
import CategoryFilter from '@components/CategoryFilter.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import { getSlug, sort } from '@utils/lookup.js';
import { buildCollectionStructuredData, getSiteOrigin } from '@utils/structuredData.js';
import { buildCategoryBreadcrumbs, buildCategoryIntro, buildPaginatedMeta, buildPaginationUrls } from '@utils/seo.js';
import { CATEGORY_SLUGS, categories, type CategorySlug } from '../../config/categories.js';
import { getCategoryDataset } from '../../config/categoryData.js';

export function getStaticPaths() {
	return CATEGORY_SLUGS.map((slug) => ({ params: { category: slug } }));
}

const slug = Astro.params.category as CategorySlug;
const config = categories[slug];
const categoryPath = `/${config.slug}`;

const pageSize = 80;
const sortedItems = sort(getCategoryDataset(config.datasets));
const pageData = sortedItems.slice(0, pageSize);
const lastPage = Math.max(1, Math.ceil(sortedItems.length / pageSize));
const page = {
	data: pageData,
	currentPage: 1,
	lastPage,
	url: {
		next: lastPage > 1 ? `${categoryPath}/2` : undefined,
	},
};

const siteOrigin = getSiteOrigin(Astro.site, Astro.url);
const canonicalUrl = new URL(categoryPath, siteOrigin).toString();
const itemListElements = page.data.map((item, index) => ({
	name: item.Name,
	url: `${siteOrigin}${getSlug(item)}`,
	position: index + 1,
}));
const structuredData = buildCollectionStructuredData({
	siteOrigin,
	canonicalUrl,
	collectionName: config.h1,
	collectionDescription: config.description,
	collectionPath: categoryPath,
	...(config.firstPagePath ? { firstPagePath: config.firstPagePath } : {}),
	currentPage: page.currentPage,
	items: itemListElements,
});
const breadcrumbs = config.firstPagePath
	? buildCategoryBreadcrumbs(config.h1, categoryPath, page.currentPage, config.firstPagePath)
	: buildCategoryBreadcrumbs(config.h1, categoryPath, page.currentPage);
const intro = buildCategoryIntro(config.intro, page.currentPage, page.lastPage);
const { title, description } = buildPaginatedMeta(
	config.metaTitle,
	config.description,
	page.currentPage,
	page.lastPage
);
const { nextUrl } = buildPaginationUrls(siteOrigin, page);
---

<Layout
	{title}
	{description}
	slug={config.slug}
	structuredData={structuredData}
	nextUrl={nextUrl}
>
	<Breadcrumbs items={breadcrumbs} className="pt-4 mb-6" />
	<h1 class="text-center text-4xl sm:text-6xl mt-12 mb-3">{config.h1}</h1>
	<p class="mx-auto mb-12 max-w-3xl text-center text-sky-200/90">{intro}</p>
	<CategoryFilter type={config.slug} basePath={categoryPath} />
</Layout>
