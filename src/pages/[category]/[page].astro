---
import Layout from '@layouts/Layout.astro';
import CompactCard from '@components/CompactCard.astro';
import Pagination from '@components/Pagination.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import { getSlug, sort } from '@utils/lookup.js';
import { buildCollectionStructuredData, getSiteOrigin } from '@utils/structuredData.js';
import { buildCategoryBreadcrumbs, buildCategoryIntro, buildPaginatedMeta, buildPaginationUrls } from '@utils/seo.js';
import type { Item } from '@utils/lookup.js';
import { CATEGORY_SLUGS, categories, type CategorySlug } from '../../config/categories.js';
import { getCategoryDataset } from '../../config/categoryData.js';
import { SITE } from '@config';

export async function getStaticPaths({ paginate }: { paginate: <T>(data: T[], options: { pageSize: number; params?: Record<string, string> }) => unknown[] }) {
	return CATEGORY_SLUGS.flatMap((slug) => {
		const config = categories[slug];
		const pages = paginate(sort(getCategoryDataset(config.datasets)), {
			pageSize: 80,
			params: { category: slug },
		});
		return pages.slice(1);
	});
}

interface PageProps {
	page: {
		data: Item[];
		currentPage: number;
		lastPage: number;
		url: {
			prev?: string;
			next?: string;
		};
	};
}

const slug = Astro.params.category as CategorySlug;
const config = categories[slug];
const categoryPath = `/${config.slug}`;
const { page } = Astro.props as PageProps;
const baseDescription = config.pageDescription ?? config.description;
const introText = config.pageIntro ?? config.intro;

const siteOrigin = getSiteOrigin(Astro.site, Astro.url);
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin).toString();
const itemListElements = page.data.map((item, index) => ({
	name: item.Name,
	url: `${siteOrigin}${getSlug(item)}`,
	position: (page.currentPage - 1) * 80 + index + 1,
}));
const structuredData = buildCollectionStructuredData({
	siteOrigin,
	canonicalUrl,
	collectionName: config.h1,
	collectionDescription: baseDescription,
	collectionPath: categoryPath,
	...(config.firstPagePath ? { firstPagePath: config.firstPagePath } : {}),
	currentPage: page.currentPage,
	items: itemListElements,
});
const breadcrumbs = config.firstPagePath
	? buildCategoryBreadcrumbs(config.h1, categoryPath, page.currentPage, config.firstPagePath)
	: buildCategoryBreadcrumbs(config.h1, categoryPath, page.currentPage);
const intro = buildCategoryIntro(introText, page.currentPage, page.lastPage);
const { title, description } = buildPaginatedMeta(
	config.metaTitle,
	baseDescription,
	page.currentPage,
	page.lastPage
);
const { prevUrl, nextUrl } = buildPaginationUrls(siteOrigin, page);
---

<Layout
	{title}
	{description}
	slug={config.slug}
	structuredData={structuredData}
	prevUrl={prevUrl}
	nextUrl={nextUrl}
>
	<Breadcrumbs items={breadcrumbs} className="pt-4 mb-6" />
	<h1 class="text-center text-4xl sm:text-6xl mt-12 mb-3">{config.h1}</h1>
	<p class="mx-auto mb-12 max-w-3xl text-center text-sky-200/90">{intro}</p>
	<div id="items" class="grid grid-cols-2 gap-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 xl:grid-cols-8">
		{
			page.data.map((item, index) => (
				<CompactCard
					card={{
						name: item.Name,
						image: SITE.imageBaseUrl + item.Icon,
						link: getSlug(item),
					}}
					index={index}
				/>
			))
		}
	</div>
	<Pagination page={page} />
</Layout>
