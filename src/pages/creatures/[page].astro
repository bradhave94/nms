---
import Layout from '@layouts/Layout.astro';
import CompactCard from '@components/CompactCard.astro';
import Pagination from '@components/Pagination.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import { buildCollectionStructuredData, getSiteOrigin } from '@utils/structuredData.js';
import { buildCategoryBreadcrumbs, buildCategoryIntro, buildPaginatedMeta } from '@utils/seo.js';
import creaturesData from '@datav2/Creatures.json';

type CreatureSpecies = {
	Id: string;
	Name: string;
	SpeciesSubtitle?: string | null;
	BattleForcedAffinity?: string | null;
	CanBeUsedInBattle?: boolean;
	Icon?: string | null;
	BattleAffinityIcon?: string | null;
	Slug?: string;
};

const IMAGE_BASE = 'https://nomansskyrecipes.com/images/items/';
const PAGE_SIZE = 80;

export async function getStaticPaths() {
	const pageSize = 80;
	const pageSpecies = ((creaturesData as { Species?: CreatureSpecies[] }).Species ?? [])
		.filter((item): item is CreatureSpecies => Boolean(item?.Id && item?.Name))
		.slice()
		.sort((a, b) => a.Name.localeCompare(b.Name));
	const pageCount = Math.ceil(pageSpecies.length / pageSize);
	return Array.from({ length: Math.max(0, pageCount - 1) }, (_, i) => {
		const pageNumber = i + 2;
		const start = (pageNumber - 1) * pageSize;
		const end = start + pageSize;
		return {
			params: { page: String(pageNumber) },
			props: {
				page: {
					data: pageSpecies.slice(start, end),
					currentPage: pageNumber,
					lastPage: pageCount,
					url: {
						prev: pageNumber > 1 ? `/creatures/${pageNumber - 1}` : undefined,
						next: pageNumber < pageCount ? `/creatures/${pageNumber + 1}` : undefined,
					},
				},
			},
		};
	});
}

type PageProp = {
	page: {
		data: CreatureSpecies[];
		currentPage: number;
		lastPage: number;
		url: {
			prev?: string;
			next?: string;
		};
	};
};

const { page } = Astro.props as PageProp;
const siteOrigin = getSiteOrigin(Astro.site, Astro.url);
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin).toString();
const itemListElements = page.data.map((item, index) => ({
	name: item.Name,
	url: `${siteOrigin}/creatures/${item.Id}`,
	position: (page.currentPage - 1) * PAGE_SIZE + index + 1,
}));
const structuredData = buildCollectionStructuredData({
	siteOrigin,
	canonicalUrl,
	collectionName: 'Creatures',
	collectionDescription:
		"No Man's Sky creature species and Xeno Arena companions, with battle affinities and move archetypes.",
	collectionPath: '/creatures',
	currentPage: page.currentPage,
	items: itemListElements,
});
const breadcrumbs = buildCategoryBreadcrumbs('Creatures', '/creatures', page.currentPage);
const intro = buildCategoryIntro(
	'Browse creature species used in the Xeno Arena update, including battle affinity indicators and companion metadata.',
	page.currentPage,
	page.lastPage
);
const baseDescription =
	"No Man's Sky creature species and Xeno Arena companions, with battle affinities and move archetypes.";
const { title, description } = buildPaginatedMeta(
	'Creatures',
	baseDescription,
	page.currentPage,
	page.lastPage
);

const iconFor = (item: CreatureSpecies): string => {
	if (item.Icon) return item.Icon;
	if (item.BattleAffinityIcon) return item.BattleAffinityIcon;
	return 'SPEC_PB_EGG01.png';
};

const cardNameFor = (item: CreatureSpecies): string => {
	const subtitle = item.SpeciesSubtitle?.trim();
	if (subtitle) return `${item.Name} • ${subtitle}`;
	return item.Name;
};
---

<Layout
	{title}
	{description}
	slug="creatures"
	structuredData={structuredData}
>
	<Breadcrumbs items={breadcrumbs} className="pt-4 mb-6" />
	<h1 class="text-center text-4xl sm:text-6xl mt-12 mb-3">Creatures</h1>
	<p class="mx-auto mb-12 max-w-3xl text-center text-sky-200/90">{intro}</p>
	<div id="items" class="grid grid-cols-2 gap-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 xl:grid-cols-8">
		{
			page.data.map((item, index) => (
				<CompactCard
					card={{
						name: cardNameFor(item),
						image: `${IMAGE_BASE}${iconFor(item)}`,
						link: `/creatures/${item.Id}`,
					}}
					index={index}
				/>
			))
		}
	</div>
	<Pagination page={page} />
</Layout>
