---
import Layout from '@layouts/Layout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import creaturesData from '@datav2/Creatures.json';

type CreatureAffinity = (typeof creaturesData.Affinities)[number];

const IMAGE_BASE = 'https://nomansskyrecipes.com/images/items/';
const affinities = creaturesData.Affinities ?? [];
const affinityById = new Map<string, CreatureAffinity>(
	affinities.map((affinity) => [affinity.Id, affinity] as const)
);

const matchups = [
	{ affinityId: 'Fire', strongAgainstId: 'Cold', weakAgainstId: 'Radioactive' },
	{ affinityId: 'Cold', strongAgainstId: 'Barren', weakAgainstId: 'Fire' },
	{ affinityId: 'Radioactive', strongAgainstId: 'Fire', weakAgainstId: 'Toxic' },
	{ affinityId: 'Toxic', strongAgainstId: 'Lush', weakAgainstId: 'Mech' },
	{ affinityId: 'Mech', strongAgainstId: 'Toxic', weakAgainstId: 'Weird' },
	{ affinityId: 'Weird', strongAgainstId: 'Mech', weakAgainstId: 'Barren' },
	{ affinityId: 'Barren', strongAgainstId: 'Radioactive', weakAgainstId: 'Cold' },
	{ affinityId: 'Lush', strongAgainstId: 'Weird', weakAgainstId: 'Toxic' },
];

const displayNameFor = (affinityId: string): string =>
	affinityById.get(affinityId)?.DisplayName ?? affinityId;
const iconFor = (affinityId: string): string | null => affinityById.get(affinityId)?.Icon ?? null;

const title = "Creature Affinities | No Man's Sky Recipes";
const description =
	"See the eight Xeno Arena creature affinities and the strength-versus-weakness matchup chart.";
const breadcrumbs = [
	{ name: 'Home', href: '/' },
	{ name: 'Creatures', href: '/creatures' },
	{ name: 'Affinities' },
];
---

<Layout title={title} description={description} slug="creatures">
	<Breadcrumbs items={breadcrumbs} className="pt-4 mb-6" />
	<section class="mx-auto max-w-6xl px-4 pb-10">
		<h1 class="text-center text-4xl sm:text-6xl mt-12 mb-3">Affinity System</h1>
		<p class="mx-auto mb-10 max-w-4xl text-center text-sky-200/90">
			Winning Arena battles depends on affinity matchups. Use this chart to plan favorable counters and
			avoid weak pairings.
		</p>

		<div class="mb-8 grid grid-cols-2 gap-3 sm:grid-cols-4 lg:grid-cols-8">
			{
				matchups.map((row) => {
					const icon = iconFor(row.affinityId);
					return (
						<div class="rounded-sm border border-sky-800/70 bg-sky-950/40 px-3 py-4 text-center">
							{icon && (
								<img
									src={`${IMAGE_BASE}${icon}`}
									alt={`${displayNameFor(row.affinityId)} icon`}
									class="mx-auto mb-2 h-10 w-10"
									loading="lazy"
								/>
							)}
							<p class="m-0 text-sm font-semibold text-white">{displayNameFor(row.affinityId)}</p>
						</div>
					);
				})
			}
		</div>

		<div class="overflow-x-auto rounded-sm border border-sky-800/70 bg-sky-950/40">
			<table class="min-w-full border-collapse">
				<thead>
					<tr class="bg-sky-600/90 text-left text-sm uppercase tracking-wide text-white">
						<th class="px-4 py-3">Affinity</th>
						<th class="px-4 py-3">Strong Against</th>
						<th class="px-4 py-3">Weak Against</th>
					</tr>
				</thead>
				<tbody>
					{
						matchups.map((row) => (
							<tr class="border-t border-sky-800/60 text-sm">
								<td class="px-4 py-3 text-sky-100">{displayNameFor(row.affinityId)}</td>
								<td class="px-4 py-3 text-lime-300">{displayNameFor(row.strongAgainstId)}</td>
								<td class="px-4 py-3 text-amber-300">{displayNameFor(row.weakAgainstId)}</td>
							</tr>
						))
					}
				</tbody>
			</table>
		</div>
	</section>
</Layout>
