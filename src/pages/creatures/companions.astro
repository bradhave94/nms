</Layout>

<script>
const sections = ['leveling', 'behaviours', 'egg-sequencer', 'accessories', 'moods', 'records'];
const links = document.querySelectorAll('.toc-link');

function updateActive() {
	let current = '';
	for (const id of sections) {
		const el = document.getElementById(id);
		if (el) {
			const rect = el.getBoundingClientRect();
			if (rect.top <= 120) current = id;
		}
	}
	links.forEach(link => {
		const section = link.getAttribute('data-section');
		if (section === current) {
			link.classList.remove('text-sky-300/80');
			link.classList.add('text-white', 'font-semibold', 'border-l-2', 'border-sky-400', 'pl-2');
		} else {
			link.classList.add('text-sky-300/80');
			link.classList.remove('text-white', 'font-semibold', 'border-l-2', 'border-sky-400', 'pl-2');
		}
	});
}

window.addEventListener('scroll', updateActive, { passive: true });
updateActive();
</script>
