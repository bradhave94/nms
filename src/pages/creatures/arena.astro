---
import Layout from '@layouts/Layout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import creaturesData from '@datav2/Creatures.json';
import { getById, getSlug } from '@utils/lookup.js';
import { SITE } from '@config';

type ArenaMode = {
	Id: string;
	Name: string;
	Description?: string | null;
	Difficulty?: string | null;
	GameMode: string;
	RewardWin: string | null;
	RewardLoss: string | null;
	ExperienceMultiplier: number;
};

type LeagueLevel = {
	LevelName: string;
	Threshold: number;
};

type ArenaLeague = {
	Id: string;
	StatTitle: string;
	Levels: LeagueLevel[];
	MedalName?: string | null;
	MedalDescription?: string | null;
	WikiName?: string | null;
	WikiDescription?: string | null;
};

type RewardItem = {
	Type: string;
	Id?: string | null;
	ProductId?: string | null;
	StatId?: string | null;
	AmountMin?: number;
	AmountMax?: number;
	Amount?: number;
	Chance: number;
};

type ArenaReward = {
	Id: string;
	RewardChoice: string;
	IncrementStat: string | null;
	Items: RewardItem[];
};

type PetShopItem = {
	Id: string;
	ProductID: string;
	Icon: string;
	Name: string;
	Group: string;
	Description: string;
	IconPath: string;
	LinkedRewardID: string;
	RequiredStat: string;
	RequiredStatTier: number;
	Price: number;
};

const data = creaturesData as Record<string, unknown>;
const IMAGE_BASE = SITE.imageBaseUrl;

const globals = (data.CreatureGlobals as Record<string, unknown>) ?? {};
const arenaGuild = globals.ArenaGuild as { Name?: string; Description?: string } | undefined;
const battleUI = globals.BattleUI as Record<string, string> | undefined;
const holoArenaHeader = battleUI?.MAIN_HEADER ?? 'Creature Battles';

const arenaModes = (data.ArenaModes as ArenaMode[] | undefined) ?? [];
const arenaLeagues = (data.ArenaLeague as ArenaLeague[] | undefined) ?? [];
const arenaRewards = (data.ArenaRewards as ArenaReward[] | undefined) ?? [];
const petShop = (data.PetShop as PetShopItem[] | undefined) ?? [];

const rewardById = new Map<string, ArenaReward>(
	arenaRewards.filter((r) => Boolean(r?.Id)).map((r) => [r.Id, r] as const),
);
const leagueById = new Map<string, ArenaLeague>(
	arenaLeagues.filter((l) => Boolean(l?.Id)).map((l) => [l.Id, l] as const),
);

const difficultyColor: Record<string, string> = {
	'Player vs Player': 'border-violet-500 bg-violet-500/20 text-violet-200',
	Easy: 'border-emerald-500 bg-emerald-500/20 text-emerald-200',
	Medium: 'border-amber-500 bg-amber-500/20 text-amber-200',
	Hard: 'border-red-500 bg-red-500/20 text-red-200',
};

const toTitleCase = (value: string): string =>
	value
		.replace(/[_-]+/g, ' ')
		.trim()
		.split(/\s+/)
		.map((word) => {
			const lower = word.toLowerCase();
			if (!lower) return word;
			if (lower === 'pvp') return 'PvP';
			if (lower === 'pve') return 'PvE';
			return lower.charAt(0).toUpperCase() + lower.slice(1);
		})
		.join(' ');

const _PRODUCT_NAMES: Record<string, string> = {
	CHART_PB_CHALNX: "Champion's Invitation",
	CHART_PB_CHALL: "Challenger's Invitation",
	TREAT_FREELEVEL: 'Retroviral Pellet',
};

function rewardItemParts(item: RewardItem): { label: string; href?: string; chanceSuffix?: string } {
	const chanceSuffix = item.Chance < 100 ? ` (${item.Chance}%)` : '';
	if (item.Type === 'Currency' && item.Id === 'Nanites') {
		return {
			label: `${item.AmountMin}–${item.AmountMax} Nanites`,
			href: getSlug('TECHFRAG'),
			chanceSuffix,
		};
	}
	if (item.Type === 'Product' && item.ProductId) {
		const product = getById(item.ProductId);
		return {
			label: product?.Name ?? toTitleCase(item.ProductId),
			href: getSlug(item.ProductId),
			chanceSuffix,
		};
	}
	return { label: toTitleCase(item.Id ?? item.Type), chanceSuffix };
}

function summarizeReward(reward: ArenaReward | undefined): string {
	if (!reward) return 'None';
	const parts: string[] = [];
	for (const item of reward.Items) {
		const part = rewardItemParts(item);
		parts.push(`${part.label}${part.chanceSuffix ?? ''}`);
	}
	return parts.length > 0 ? parts.join(', ') : 'League stat progress';
}

const petBattlerModes = arenaModes.filter((m) => m.GameMode === 'Creature Battle');
const diceGameModes = arenaModes.filter((m) => m.GameMode === 'Dice Game');

const title = "Xeno Arena | No Man's Sky Recipes";
const description =
	'Explore the Xeno Arena system: battle modes, league progression, AI difficulty, rewards, and pet shop eggs.';
const breadcrumbs = [
	{ name: 'Home', href: '/' },
	{ name: 'Creatures', href: '/creatures' },
	{ name: 'Arena' },
];
---

<Layout title={title} description={description} slug="creatures">
	<Breadcrumbs items={breadcrumbs} className="pt-4 mb-6" />
	<section class="mx-auto max-w-7xl px-4 pb-12">
		<h1 class="text-center text-4xl sm:text-6xl mt-12 mb-3">Xeno Arena</h1>
		<p class="mx-auto mb-10 max-w-5xl text-center text-sky-200/90">
			Battle modes, league ladders, and exclusive reward eggs from the Xeno Arena system.
		</p>

		{arenaGuild?.Description && (
			<p class="mx-auto mb-8 max-w-5xl text-sm text-sky-200/80 leading-relaxed">{arenaGuild.Description}</p>
		)}

		{/* ── Section 1: Arena Modes ── */}
		<section class="mb-12">
			<h2 class="mb-1 text-2xl text-white">Arena Modes</h2>
			<p class="mt-0 mb-6 text-sm text-sky-300/80">
				Modes are grouped by game type. Each card shows the difficulty, win reward, and XP multiplier.
			</p>

			<h3 class="mb-3 text-lg text-sky-100">{holoArenaHeader}</h3>
			<div class="mb-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
				{petBattlerModes.map((mode) => {
					const diff = mode.Difficulty ?? 'Unknown';
					const colors = difficultyColor[diff] ?? 'border-sky-700 bg-sky-700/20 text-sky-200';
					const winReward = mode.RewardWin ? rewardById.get(mode.RewardWin) : undefined;
					return (
						<article class="rounded-sm border border-sky-800/70 bg-sky-950/40 p-4">
							<div class="mb-2 flex items-start justify-between gap-2">
								<h4 class="m-0 text-lg text-white">{mode.Name}</h4>
								<span class={`shrink-0 rounded-full border px-2.5 py-0.5 text-xs font-semibold ${colors}`}>
									{diff}
								</span>
							</div>
							{mode.Description && (
								<p class="m-0 mb-2 text-sm text-sky-200/80">{mode.Description}</p>
							)}
							<div class="mt-3 space-y-1 text-sm text-sky-200/90">
								<p class="m-0">
									<span class="font-semibold text-sky-100">Win:</span>{' '}
									{winReward && winReward.Items.length > 0 ? (
										winReward.Items.map((rewardItem, index) => {
											const part = rewardItemParts(rewardItem);
											return (
												<>
													{index > 0 && ', '}
													{part.href ? (
														<a href={part.href} class="text-cyan-300 hover:text-cyan-200">
															{part.label}
														</a>
													) : (
														part.label
													)}
													{part.chanceSuffix}
												</>
											);
										})
									) : (
										summarizeReward(winReward)
									)}
								</p>
								{mode.ExperienceMultiplier !== 1.0 && (
									<p class="m-0">
										<span class="font-semibold text-sky-100">XP Multiplier:</span>{' '}
										{mode.ExperienceMultiplier}×
									</p>
								)}
							</div>
						</article>
					);
				})}
			</div>

			{diceGameModes.length > 0 && (
				<>
					<h3 class="mb-3 text-lg text-sky-100">Dice Game</h3>
					<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
						{diceGameModes.map((mode) => {
							const diff = mode.Difficulty ?? 'Unknown';
							const colors = difficultyColor[diff] ?? 'border-sky-700 bg-sky-700/20 text-sky-200';
							const winReward = mode.RewardWin ? rewardById.get(mode.RewardWin) : undefined;
							return (
								<article class="rounded-sm border border-sky-800/70 bg-sky-950/40 p-4">
									<div class="mb-2 flex items-start justify-between gap-2">
										<h4 class="m-0 text-lg text-white">{mode.Name}</h4>
										<span class={`shrink-0 rounded-full border px-2.5 py-0.5 text-xs font-semibold ${colors}`}>
											{diff}
										</span>
									</div>
									{mode.Description && (
										<p class="m-0 mb-2 text-sm text-sky-200/80">{mode.Description}</p>
									)}
									<div class="mt-3 space-y-1 text-sm text-sky-200/90">
										<p class="m-0">
											<span class="font-semibold text-sky-100">Win:</span>{' '}
											{winReward && winReward.Items.length > 0 ? (
												winReward.Items.map((rewardItem, index) => {
													const part = rewardItemParts(rewardItem);
													return (
														<>
															{index > 0 && ', '}
															{part.href ? (
																<a href={part.href} class="text-cyan-300 hover:text-cyan-200">
																	{part.label}
																</a>
															) : (
																part.label
															)}
															{part.chanceSuffix}
														</>
													);
												})
											) : (
												summarizeReward(winReward)
											)}
										</p>
										{mode.ExperienceMultiplier !== 1.0 && (
											<p class="m-0">
												<span class="font-semibold text-sky-100">XP Multiplier:</span>{' '}
												{mode.ExperienceMultiplier}×
											</p>
										)}
									</div>
								</article>
							);
						})}
					</div>
				</>
			)}
		</section>

		{/* ── Section 2: League Progression ── */}
		<section class="mb-12">
			<h2 class="mb-1 text-2xl text-white">League Progression</h2>
			<p class="mt-0 mb-6 text-sm text-sky-300/80">
				Four stat-based ladders track your Arena career. Reach higher tiers to unlock pet shop rewards.
			</p>
			<div class="space-y-3">
				{arenaLeagues.map((league) => (
					<details class="rounded-sm border border-sky-800/70 bg-sky-950/35 p-4">
						<summary class="cursor-pointer list-none text-white">
							<span class="text-xl font-semibold">{league.StatTitle}</span>
							<span class="ml-2 text-xs uppercase tracking-wide text-sky-300/90">
								{league.Levels.length} tiers
							</span>
						</summary>
						{league.WikiDescription && (
							<p class="mt-2 mb-3 text-sm text-sky-200/80">{league.WikiDescription}</p>
						)}
						<div class="mt-4 overflow-x-auto">
							<table class="min-w-full border-collapse text-sm">
								<thead>
									<tr class="bg-sky-600/90 text-left text-xs uppercase tracking-wide text-white">
										<th class="px-4 py-2">Tier</th>
										<th class="px-4 py-2">Title</th>
										<th class="px-4 py-2">Threshold</th>
									</tr>
								</thead>
								<tbody>
									{league.Levels.map((level, idx) => (
										<tr class={`border-t border-sky-800/60 ${idx % 2 === 0 ? 'bg-sky-950/30' : 'bg-black/20'}`}>
											<td class="px-4 py-2 text-sky-400">{idx}</td>
											<td class="px-4 py-2 text-sky-100">{level.LevelName}</td>
											<td class="px-4 py-2 text-sky-200/80">{level.Threshold}</td>
										</tr>
									))}
								</tbody>
							</table>
						</div>
					</details>
				))}
			</div>
		</section>

		{/* ── Section 3: Pet Shop Reward Eggs ── */}
		<section>
			<h2 class="mb-1 text-2xl text-white">Pet Shop Reward Eggs</h2>
			<p class="mt-0 mb-6 text-sm text-sky-300/80">
				Exclusive companion eggs earned by reaching league milestones.
			</p>
			<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
				{petShop.map((egg) => {
					const league = leagueById.get(egg.RequiredStat);
					const statLabel = league?.StatTitle ?? toTitleCase(egg.RequiredStat);
					return (
						<article
							id={`pet-shop-${egg.Id}`}
							class="flex flex-col rounded-sm border border-sky-800/70 bg-sky-950/40 p-4 scroll-mt-24"
						>
							<div class="mb-3 flex items-start gap-3">
								<img
									src={`${IMAGE_BASE}${egg.Icon}`}
									alt={egg.Name}
									class="h-16 w-16 shrink-0 rounded-sm border border-sky-800/60 bg-black/30 p-1"
									loading="lazy"
								/>
								<div class="min-w-0">
									<h3 class="m-0 text-lg text-white">
										<a href={getSlug(egg.ProductID)} class="text-white hover:text-cyan-200">
											{egg.Name}
										</a>
									</h3>
									<p class="m-0 text-xs uppercase tracking-wide text-sky-300/90">{egg.Group}</p>
								</div>
							</div>
							<p class="mt-0 mb-3 flex-1 text-sm leading-relaxed text-sky-200/80 whitespace-pre-line">
								{egg.Description}
							</p>
							<span class="mt-auto inline-block self-start rounded-full border border-sky-600 bg-sky-800/30 px-3 py-1 text-xs font-semibold text-sky-100">
								Requires: {statLabel} Tier {egg.RequiredStatTier}
							</span>
						</article>
					);
				})}
			</div>
		</section>
	</section>
</Layout>
