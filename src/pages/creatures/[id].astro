---
import Layout from '@layouts/Layout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import type { BreadcrumbItem } from '@utils/seo.js';
import { getSiteOrigin } from '@utils/structuredData.js';
import creaturesData from '@datav2/Creatures.json';

type CreatureSpecies = (typeof creaturesData.Species)[number];
type CreatureMove = (typeof creaturesData.BattleMoves)[number];
type CreatureMoveSet = (typeof creaturesData.MoveSets)[number];
type CreatureAffinity = (typeof creaturesData.Affinities)[number];

const battleMoves = creaturesData.BattleMoves ?? [];
const moveSets = creaturesData.MoveSets ?? [];
const affinities = creaturesData.Affinities ?? [];

const moveById = new Map<string, CreatureMove>(
	battleMoves.map((move) => [move.Id, move] as const)
);
const moveSetById = new Map<string, CreatureMoveSet>(
	moveSets.map((moveSet) => [moveSet.Id, moveSet] as const)
);
const affinityIconById = new Map<string, string>(
	affinities
		.filter((affinity): affinity is CreatureAffinity => Boolean(affinity?.Id && affinity?.Icon))
		.map((affinity) => [affinity.Id, affinity.Icon] as const)
);
const speciesLabelCounts = ((creaturesData.Species ?? []) as CreatureSpecies[]).reduce<Map<string, number>>(
	(counts, entry) => {
		if (!entry?.Name) return counts;
		const subtitle = entry.SpeciesSubtitle?.trim();
		const label = subtitle ? `${entry.Name} (${subtitle})` : entry.Name;
		counts.set(label, (counts.get(label) ?? 0) + 1);
		return counts;
	},
	new Map()
);

const DEFAULT_IMAGE_BASE = 'https://nomansskyrecipes.com/images/items/';
const NORMAL_AFFINITY_ICON = 'moves--move.pet.attack.png';
const imageBase = DEFAULT_IMAGE_BASE;

type ResolvedMove = {
	id: string;
	name: string;
	displayName: string;
	description: string | null;
	category: string | null;
	affinity: string | null;
	icon: string | null;
	slug: string;
	sourceTemplateId: string;
	nameStub: string;
	optionWeight: number;
	namesByAffinity: Record<string, string> | null;
};

type ResolvedMoveSet = {
	id: string;
	name: string;
	slotCount: number;
	resolvedMoves: ResolvedMove[];
};

const toTitleCase = (value: string): string =>
	value
		.replace(/[_-]+/g, ' ')
		.trim()
		.split(/\s+/)
		.map((word) => {
			if (!word) return word;
			const lower = word.toLowerCase();
			if (lower === 'pvp') return 'PvP';
			if (lower === 'pve') return 'PvE';
			return word.charAt(0).toUpperCase() + word.slice(1).toLowerCase();
		})
		.join(' ');

const AFFINITY_LABELS: Record<string, string> = {
	Fire: 'Fire',
	Cold: 'Frost',
	Toxic: 'Toxic',
	Barren: 'Desert',
	Lush: 'Tropical',
	Radioactive: 'Radioactive',
	Mech: 'Mechanical',
	Weird: 'Anomalous',
	None: 'Physical',
	UsePetAffinity: 'Matches Creature Affinity',
};

const ALL_BATTLE_AFFINITIES = [
	'Fire',
	'Frost',
	'Toxic',
	'Desert',
	'Tropical',
	'Radioactive',
	'Mechanical',
	'Anomalous',
];

const formatAffinity = (value: string | null | undefined): string =>
	value ? (AFFINITY_LABELS[value] ?? toTitleCase(value)) : 'None';

const formatCategory = (value: string | null | undefined): string =>
	value ? toTitleCase(value) : 'Uncategorized';

const getPreferredMoveLabel = (move: CreatureMove, species: CreatureSpecies): string => {
	const namesByAffinity = move.NamesByAffinity;
	if (namesByAffinity && typeof namesByAffinity === 'object') {
		const forcedAffinity = species.BattleForcedAffinity ?? '';
		if (forcedAffinity && namesByAffinity[forcedAffinity as keyof typeof namesByAffinity]) {
			return String(namesByAffinity[forcedAffinity as keyof typeof namesByAffinity]);
		}
		if (move.Affinity && namesByAffinity[move.Affinity as keyof typeof namesByAffinity]) {
			return String(namesByAffinity[move.Affinity as keyof typeof namesByAffinity]);
		}
		if (namesByAffinity.Normal) return String(namesByAffinity.Normal);
	}
	return move.DefaultDisplayName ?? move.Name ?? move.NameStub ?? move.Id;
};

const MATCHUPS: Record<string, { strong: string; weak: string }> = {
	Fire: { strong: 'Cold', weak: 'Radioactive' },
	Cold: { strong: 'Barren', weak: 'Fire' },
	Radioactive: { strong: 'Fire', weak: 'Toxic' },
	Toxic: { strong: 'Lush', weak: 'Mech' },
	Mech: { strong: 'Toxic', weak: 'Weird' },
	Weird: { strong: 'Mech', weak: 'Barren' },
	Barren: { strong: 'Radioactive', weak: 'Cold' },
	Lush: { strong: 'Weird', weak: 'Toxic' },
};

const slugifyCategory = (value: string | null | undefined): string =>
	(value ?? 'uncategorized').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');

const iconForMove = (move: CreatureMove, speciesAffinity: string | null): string | null => {
	if (move.Category !== 'Attack') {
		return move.CategoryIcon;
	}
	if (move.Affinity && affinityIconById.has(move.Affinity)) {
		return affinityIconById.get(move.Affinity) ?? null;
	}
	if (move.AffinityRaw === 'UsePetAffinity' && speciesAffinity && affinityIconById.has(speciesAffinity)) {
		return affinityIconById.get(speciesAffinity) ?? null;
	}
	if (
		speciesAffinity &&
		affinityIconById.has(speciesAffinity) &&
		move.NamesByAffinity &&
		typeof move.NamesByAffinity === 'object' &&
		move.NamesByAffinity[speciesAffinity as keyof typeof move.NamesByAffinity]
	) {
		return affinityIconById.get(speciesAffinity) ?? null;
	}
	return move.CategoryIcon ?? null;
};

const resolveSpeciesMoveSetIds = (species: CreatureSpecies): string[] => {
	const explicitMoveSets = species.MoveSets;
	if (Array.isArray(explicitMoveSets) && explicitMoveSets.length > 0) {
		return explicitMoveSets;
	}
	const possibleMoveSets = species.PotentialMoveSets;
	if (Array.isArray(possibleMoveSets) && possibleMoveSets.length > 0) {
		return possibleMoveSets;
	}
	return [];
};

const resolveMovesForSpecies = (species: CreatureSpecies): ResolvedMoveSet[] => {
	const setIds = resolveSpeciesMoveSetIds(species);
	if (!Array.isArray(setIds) || setIds.length === 0) return [];
	const speciesAffinity = species.BattleForcedAffinity ?? null;

	const scoreMoveForSpecies = (move: CreatureMove): number => {
		const moveAffinity = move.Affinity ?? null;
		if (speciesAffinity && moveAffinity === speciesAffinity) return 4;
		if (!moveAffinity && move.AffinityRaw === 'Normal') return 3;
		if (!moveAffinity) return 2;
		return 1;
	};

	return setIds
		.map((setId) => {
			const moveSet = moveSetById.get(setId);
			if (!moveSet) return null;

			const seen = new Set<string>();
			const dedupedByTemplateGroup = new Map<string, ResolvedMove>();

			for (const slot of moveSet.Slots ?? []) {
				for (const option of slot.Options ?? []) {
					const templateId = option.Template;
					if (!templateId || seen.has(templateId)) continue;
					seen.add(templateId);
					const move = moveById.get(templateId);
					if (!move) continue;

					const candidate: ResolvedMove = {
						id: move.Id,
						name: move.Name ?? move.NameStub ?? move.Id,
						displayName: getPreferredMoveLabel(move, species),
						description: move.EffectDescription ?? move.Description ?? null,
						category: move.Category ?? null,
						affinity: move.Affinity ?? null,
						icon: iconForMove(move, speciesAffinity),
						slug: move.Slug ?? `creatures/moves/${move.Id}`,
						sourceTemplateId: templateId,
						nameStub: move.NameStub ?? move.Id,
						optionWeight: option.Weighting ?? 0,
						namesByAffinity:
							move.NamesByAffinity && typeof move.NamesByAffinity === 'object'
								? (move.NamesByAffinity as Record<string, string>)
								: null,
					};
					const groupKey = `${candidate.nameStub}::${candidate.category ?? ''}`;
					const existing = dedupedByTemplateGroup.get(groupKey);
					if (!existing) {
						dedupedByTemplateGroup.set(groupKey, candidate);
						continue;
					}
					const existingMove = moveById.get(existing.id);
					const existingScore = existingMove ? scoreMoveForSpecies(existingMove) : 0;
					const candidateScore = scoreMoveForSpecies(move);
					if (
						candidateScore > existingScore ||
						(candidateScore === existingScore && candidate.optionWeight > existing.optionWeight)
					) {
						dedupedByTemplateGroup.set(groupKey, candidate);
					}
				}
			}
			const resolvedMoves = Array.from(dedupedByTemplateGroup.values()).sort((a, b) =>
				a.displayName.localeCompare(b.displayName)
			);

			return {
				id: moveSet.Id,
				name: moveSet.Name ?? toTitleCase(moveSet.Id),
				slotCount: (moveSet.Slots ?? []).length,
				resolvedMoves,
			} satisfies ResolvedMoveSet;
		})
		.filter((entry): entry is ResolvedMoveSet => Boolean(entry));
};

export async function getStaticPaths() {
	const speciesList = creaturesData.Species ?? [];
	return speciesList.map((species) => ({
		params: { id: species.Id.toString() },
		props: {
			species,
		},
	}));
}

interface Props {
	species: CreatureSpecies;
}

const { species } = Astro.props as Props;

if (!species) {
	return Astro.redirect('/creatures');
}

const resolvedMoveSets = resolveMovesForSpecies(species);

const siteOrigin = getSiteOrigin(Astro.site, Astro.url);
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin).toString();

const speciesSubtitle = species.SpeciesSubtitle?.trim();
const speciesLabel = speciesSubtitle ? `${species.Name} (${speciesSubtitle})` : species.Name;
const hasDuplicateSpeciesLabel = (speciesLabelCounts.get(speciesLabel) ?? 0) > 1;
const speciesSeoQualifier = hasDuplicateSpeciesLabel ? `${speciesLabel} | ${species.Id}` : speciesLabel;
const pageTitle = `${speciesSeoQualifier} | Creatures | No Man's Sky Recipes`;
const shortDescription = hasDuplicateSpeciesLabel
	? `${speciesLabel} creature battle profile, affinities, and move sets in No Man's Sky Xeno Arena. Species ID ${species.Id}.`
	: `${speciesLabel} creature battle profile, affinities, and move sets in No Man's Sky Xeno Arena.`;
const description = shortDescription.slice(0, 180);
const speciesIcon = species.BattleAffinityIcon ?? NORMAL_AFFINITY_ICON;
const ogImage = `${imageBase}${speciesIcon}`;

const breadcrumbs: BreadcrumbItem[] = [
	{ name: 'Home', href: '/' },
	{ name: 'Creatures', href: '/creatures' },
	{ name: 'Species', href: '/creatures/species' },
	{ name: species.Name },
];

const collectionSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebPage',
	'@id': `${canonicalUrl}#page`,
	url: canonicalUrl,
	name: pageTitle,
	description,
	breadcrumb: {
		'@type': 'BreadcrumbList',
		itemListElement: [
			{ '@type': 'ListItem', position: 1, name: 'Home', item: `${siteOrigin}/` },
			{ '@type': 'ListItem', position: 2, name: 'Creatures', item: `${siteOrigin}/creatures` },
			{ '@type': 'ListItem', position: 3, name: 'Species', item: `${siteOrigin}/creatures/species` },
			{ '@type': 'ListItem', position: 4, name: species.Name, item: canonicalUrl },
		],
	},
};

type StatPill = { label: string; value: string };

const statPills: StatPill[] = [
	{ label: 'Battle Ready', value: species.CanBeUsedInBattle ? 'Yes' : 'No' },
	species.CanBeUsedInBattle
		? {
				label: 'Affinity',
				value:
					species.BattleForcedAffinityDisplay ??
					formatAffinity(species.BattleForcedAffinity) ??
					'None',
			}
		: null,
	{ label: 'Creature Type', value: species.CreatureType ? toTitleCase(species.CreatureType) : 'Unknown' },
	{ label: 'Rarity', value: species.Rarity ? toTitleCase(species.Rarity) : 'Unknown' },
	{ label: 'Move Area', value: species.MoveArea ? toTitleCase(species.MoveArea) : 'Unknown' },
	{ label: 'Scale', value: `${species.MinScale} - ${species.MaxScale}` },
	{ label: 'Egg Type', value: species.EggType ? toTitleCase(species.EggType) : 'Unknown' },
	species.CanBeUsedInBattle
		? {
				label: 'Move Set Source',
				value:
					species.MoveSetSource === 'Explicit'
						? 'Direct Mapping'
						: species.MoveSetSource === 'GlobalPool'
							? 'Global Pool'
							: 'Unknown',
			}
		: null,
	species.SpecialTrait ? { label: 'Special Trait', value: species.SpecialTrait } : null,
].filter((pill): pill is StatPill => pill != null);

const speciesMatchup =
	species.BattleForcedAffinity && MATCHUPS[species.BattleForcedAffinity]
		? MATCHUPS[species.BattleForcedAffinity]
		: null;

---

<Layout
	title={pageTitle}
	description={description}
	slug="creatures"
	structuredData={collectionSchema}
	ogImage={ogImage}
>
	<Breadcrumbs items={breadcrumbs} className="pt-4 mb-6" />
	<section class="mx-auto max-w-6xl px-4 pb-10">
		<div class="mb-8 rounded-sm border border-sky-900 bg-sky-900/30 p-5">
			<div class="flex flex-wrap items-center justify-between gap-4">
				<div>
					<h1 class="m-0 text-4xl sm:text-5xl text-white">{species.Name}</h1>
					{species.SpeciesSubtitle && (
						<p class="mt-2 text-lg text-sky-200/90">{species.SpeciesSubtitle}</p>
					)}
					<p class="mt-2 text-sm text-sky-300/80">Creature ID: {species.Id}</p>
				</div>
				<div class="flex items-center gap-3">
					<img
						src={`${imageBase}${speciesIcon}`}
						alt={`${species.Name} icon`}
						class="h-14 w-14 rounded-sm bg-black/30 p-1"
						loading="lazy"
					/>
					{species.BattleAffinityIcon && species.BattleAffinityIcon !== speciesIcon && (
						<img
							src={`${imageBase}${species.BattleAffinityIcon}`}
							alt={`${species.Name} affinity icon`}
							class="h-14 w-14 rounded-sm bg-black/30 p-1"
							loading="lazy"
						/>
					)}
				</div>
			</div>
			<div class="mt-4 grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
				{
					statPills.map((pill) => (
						<p class="m-0 rounded-sm bg-black/35 px-3 py-2 text-sm text-sky-100">
							<span class="font-semibold text-sky-300">{pill.label}:</span> {pill.value}
						</p>
					))
				}
			</div>
			{speciesMatchup && (
				<div class="mt-4 flex flex-wrap items-center gap-4 rounded-sm bg-black/35 px-4 py-3">
					<span class="text-sm text-sky-300">Matchups:</span>
					<span class="flex items-center gap-1 text-sm text-lime-300">
						{affinityIconById.get(speciesMatchup.strong) && (
							<img
								src={`${imageBase}${affinityIconById.get(speciesMatchup.strong)}`}
								class="h-5 w-5"
								alt=""
								loading="lazy"
							/>
						)}
						Strong vs {formatAffinity(speciesMatchup.strong)}
					</span>
					<span class="flex items-center gap-1 text-sm text-amber-300">
						{affinityIconById.get(speciesMatchup.weak) && (
							<img
								src={`${imageBase}${affinityIconById.get(speciesMatchup.weak)}`}
								class="h-5 w-5"
								alt=""
								loading="lazy"
							/>
						)}
						Weak vs {formatAffinity(speciesMatchup.weak)}
					</span>
				</div>
			)}
		</div>

		{species.CanBeUsedInBattle ? (
			<section class="rounded-sm border border-sky-900 bg-sky-900/20 p-5">
				<h2 class="mt-0 mb-4 text-2xl text-white">Move Set Archetypes</h2>
				<p class="mt-0 mb-4 text-xs text-sky-300/90">
					Affinity options: {ALL_BATTLE_AFFINITIES.join(' • ')}.
				</p>
				{species.MoveSetSource === 'GlobalPool' && (
					<p class="mt-0 mb-4 text-sm text-sky-300/90">
						This species has no explicit move-set assignment in the game table. Showing the full global
						move-set pool used by pet battler archetypes.
					</p>
				)}
				{
					resolvedMoveSets.length === 0 ? (
						<p class="m-0 text-sky-200/90">No direct move set mapping is available for this species yet.</p>
					) : (
						<div class="space-y-4">
							{
								resolvedMoveSets.map((moveSet) => (
									<div class="rounded-sm border border-sky-800/70 bg-black/25 p-4">
										<h3 class="mt-0 mb-1 text-xl text-sky-100">{moveSet.name}</h3>
										<p class="mt-0 mb-3 text-xs uppercase tracking-wide text-sky-300/80">
											{moveSet.id} • {moveSet.slotCount} slots • {moveSet.resolvedMoves.length} move templates
										</p>
										<div class="grid gap-2 md:grid-cols-2 xl:grid-cols-3">
											{
												moveSet.resolvedMoves.map((move) => (
													<a
														href={`/creatures/moves#category-${slugifyCategory(move.category)}`}
														class="rounded-sm border border-sky-800/70 bg-sky-950/60 px-3 py-2 text-sm text-sky-100 transition-colors hover:border-sky-400 hover:bg-sky-900/70"
													>
														<div class="flex items-center gap-2">
															{move.icon && (
																<img
																	src={`${imageBase}${move.icon}`}
																	alt={`${move.displayName} icon`}
																	class="h-6 w-6 shrink-0"
																	loading="lazy"
																/>
															)}
															<div class="min-w-0">
																<p class="m-0 truncate font-semibold text-white">{move.displayName}</p>
																<p class="m-0 truncate text-xs text-sky-300/90">
																	{formatCategory(move.category)} • {formatAffinity(move.affinity)}
																</p>
															</div>
														</div>
													{move.description && (
														<p class="mt-2 mb-0 text-xs text-sky-200/85">{move.description}</p>
													)}
												</a>
												))
											}
										</div>
									</div>
								))
							}
						</div>
					)
				}
			</section>
		) : (
			<p class="rounded-sm border border-sky-800/50 bg-sky-950/20 px-4 py-3 text-sm text-sky-300/90">
				This species cannot be used in Xeno Arena battles.
			</p>
		)}
	</section>
</Layout>
