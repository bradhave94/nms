---
import Layout from '@layouts/Layout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';
import { buildCollectionStructuredData, getSiteOrigin } from '@utils/structuredData.js';
import { buildPaginatedMeta } from '@utils/seo.js';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const titleBase = "No Man's Sky Blog";
const baseDescription =
	"Read the No Man's Sky blog for strategy posts, refiner planning, crafting walkthroughs, and other search-friendly game posts.";
const { title, description } = buildPaginatedMeta(titleBase, baseDescription, 1, 1);
const siteOrigin = getSiteOrigin(Astro.site, Astro.url);
const canonicalUrl = new URL('/blog', siteOrigin).toString();
const structuredData = buildCollectionStructuredData({
	siteOrigin,
	canonicalUrl,
	collectionName: titleBase,
	collectionDescription: baseDescription,
	collectionPath: '/blog',
	currentPage: 1,
	items: posts.map((post, index) => ({
		name: post.data.title,
		url: `${siteOrigin}/blog/${post.id}/`,
		position: index + 1,
	})),
});
const breadcrumbs = [
	{ name: 'Home', href: '/' },
	{ name: 'Blog' },
];
---

<Layout title={title} description={description} slug="blog" structuredData={structuredData}>
	<Breadcrumbs items={breadcrumbs} className="pt-4 mb-6" />
	<section class="mx-auto max-w-6xl px-4 pb-16">
		<header class="mx-auto max-w-4xl text-center">
			<h1 class="m-0 pt-8 text-4xl font-bold text-white sm:text-6xl">No Man&apos;s Sky Blog</h1>
			<p class="mx-auto mt-4 max-w-3xl text-lg text-sky-200/90">
				A small editorial blog for No Man&apos;s Sky strategy, crafting workflows, and SEO-friendly
				walkthrough content.
			</p>
		</header>

		<div class="mt-12 grid gap-6 md:grid-cols-2">
			{
				posts.map((post) => (
					<article class="rounded-xl border border-sky-900/70 bg-sky-950/40 transition hover:border-sky-400/70 hover:bg-sky-900/40">
						<a href={`/blog/${post.id}/`} class="block h-full p-6 text-inherit no-underline">
							<h2 class="mt-3 text-2xl text-white hover:text-sky-200">
								{post.data.title}
							</h2>
							<p class="mt-3 text-sky-100/85">{post.data.description}</p>
							<div class="mt-4 flex flex-wrap gap-2">
								{post.data.tags.map((tag) => (
									<span class="rounded-full bg-sky-900/70 px-3 py-1 text-xs text-sky-200">{tag}</span>
								))}
							</div>
							<p class="mt-5 text-sm text-sky-300">
								Published {post.data.pubDate.toLocaleDateString('en-US', {
									year: 'numeric',
									month: 'long',
									day: 'numeric',
								})}
							</p>
						</a>
					</article>
				))
			}
		</div>
	</section>
</Layout>
